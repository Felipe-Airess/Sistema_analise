    (SELECT IFNULL(SUM(r.valor), 0) FROM receitas r WHERE r.categoria_id = c.id AND r.empresa_id = ?) -
    (SELECT IFNULL(SUM(d.valor), 0) FROM despesas d WHERE d.categoria_id = c.id AND d.empresa_id = ?) AS lucro
    FROM categorias c
    WHERE c.empresa_id = ?
    ORDER BY lucro DESC
