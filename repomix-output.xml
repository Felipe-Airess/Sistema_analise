$mensagem = null; 

if($_SERVER['REQUEST_METHOD'] === 'POST'){
    $categoria_nome = trim($_POST['categoria_nome']);
    
    if (empty($categoria_nome)) {
        $mensagem = "O nome da categoria não pode estar vazio.";
        $mensagem_tipo = 'error';
    } else {
        try {
           
            $sql_check = "SELECT id FROM categorias WHERE empresa_id = ? AND nome = ?";
            $stmt_check = $pdo->prepare($sql_check);
            $stmt_check->execute([$empresa_id, $categoria_nome]);

            if ($stmt_check->rowCount() > 0) {
                $mensagem = "A categoria '{$categoria_nome}' já está cadastrada.";
                $mensagem_tipo = 'error';
            } else {
               
                $pdo->beginTransaction();
                $sql_insert = "INSERT INTO categorias (empresa_id, nome) VALUES (?, ?)";
                $stmt_insert = $pdo->prepare($sql_insert);
                $stmt_insert->execute([$empresa_id, $categoria_nome]);
                $pdo->commit();
                
                
                header("location:gerenciar_categorias.php");
                exit();
            }
        } catch (Exception $e) {
            if ($pdo->inTransaction()) {
                $pdo->rollBack();
            }
            $mensagem = "Erro ao adicionar categoria: " . $e->getMessage();
            $mensagem_tipo = 'error';
        }
    }
}

